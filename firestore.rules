rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all denies all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable, hardened primitive helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isStandardUrl(url) {
      return url is string && url.size() <= 950000;
    }

    // Schema Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'brand', 'category', 'price', 'description', 'image', 'stockStatus', 'quantity'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.brand is string && data.brand.size() <= 128
        && data.category is string && data.category.size() <= 128
        && data.price is number && data.price >= 0
        && data.description is string && data.description.size() <= 10000
        && isStandardUrl(data.image)
        && data.stockStatus is string && data.stockStatus.size() <= 64
        && data.quantity is number && data.quantity >= 0;
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'image'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 256
        && data.category is string && data.category.size() <= 128
        && isStandardUrl(data.image)
        && (!data.keys().contains('caption') || (data.caption is string && data.caption.size() <= 5000))
        && (!data.keys().contains('beforeImage') || isStandardUrl(data.beforeImage));
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['id', 'title', 'excerpt', 'body', 'category', 'date', 'image', 'author', 'shares'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 512
        && data.excerpt is string && data.excerpt.size() <= 2000
        && data.body is string && data.body.size() <= 50000
        && data.category is string && data.category.size() <= 128
        && data.date is string && data.date.size() <= 64
        && isStandardUrl(data.image)
        && data.author is string && data.author.size() <= 128
        && data.shares is number && data.shares >= 0;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'email', 'purpose', 'message', 'date', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 256
        && data.phone is string && data.phone.size() <= 64
        && data.email is string && data.email.size() <= 256
        && data.purpose is string && data.purpose.size() <= 128
        && data.message is string && data.message.size() <= 5000
        && data.date is string && data.date.size() <= 64
        && data.status is string && data.status.size() <= 64;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customerName', 'customerPhone', 'items', 'subtotal', 'status', 'date'])
        && data.id is string && data.id.size() <= 128
        && data.customerName is string && data.customerName.size() <= 256
        && data.customerPhone is string && data.customerPhone.size() <= 64
        && data.items is list
        && data.subtotal is number && data.subtotal >= 0
        && data.status is string && data.status.size() <= 64
        && data.date is string && data.date.size() <= 64;
    }

    function isValidServiceBooking(data) {
      return data.keys().hasAll(['id', 'serviceName', 'date', 'customerName', 'customerPhone', 'location', 'details', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.serviceName is string && data.serviceName.size() <= 256
        && data.date is string && data.date.size() <= 64
        && data.customerName is string && data.customerName.size() <= 256
        && data.customerPhone is string && data.customerPhone.size() <= 64
        && data.location is string && data.location.size() <= 512
        && data.details is string && data.details.size() <= 5000
        && data.status is string && data.status.size() <= 64;
    }

    function isValidSupportTicket(data) {
      return data.keys().hasAll(['id', 'referenceNumber', 'customerName', 'customerPhone', 'issueType', 'description', 'status', 'lastUpdated', 'date'])
        && data.id is string && data.id.size() <= 128
        && data.referenceNumber is string && data.referenceNumber.size() <= 128
        && data.customerName is string && data.customerName.size() <= 256
        && data.customerPhone is string && data.customerPhone.size() <= 64
        && data.issueType is string && data.issueType.size() <= 128
        && data.description is string && data.description.size() <= 5000
        && data.status is string && data.status.size() <= 64
        && data.lastUpdated is string && data.lastUpdated.size() <= 64
        && data.date is string && data.date.size() <= 64;
    }

    // Rules matching for each collection explicitly
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidId(productId) && isValidProduct(request.resource.data);
      allow delete: if true;
    }

    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update: if isValidId(galleryId) && isValidGalleryItem(request.resource.data);
      allow delete: if true;
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update: if isValidId(blogId) && isValidBlogPost(request.resource.data);
      allow delete: if true;
    }

    match /leads/{leadId} {
      allow read: if true;
      allow create, update: if isValidId(leadId) && isValidLead(request.resource.data);
      allow delete: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create, update: if isValidId(orderId) && isValidOrder(request.resource.data);
      allow delete: if true;
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create, update: if isValidId(bookingId) && isValidServiceBooking(request.resource.data);
      allow delete: if true;
    }

    match /tickets/{ticketId} {
      allow read: if true;
      allow create, update: if isValidId(ticketId) && isValidSupportTicket(request.resource.data);
      allow delete: if true;
    }
  }
}
